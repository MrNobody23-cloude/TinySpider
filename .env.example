# ═══════════════════════════════════════════════════════════
# TinySpider — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and customize the values below.
# WARNING: Never commit .env to version control!

# ─── Runtime Configuration ────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Security Secrets ────────────────────────────────────
# ⚠️  CHANGE THESE IN PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=dev-hash-salt-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-me-in-production
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10
BCRYPT_SALT_ROUNDS=10

# ─── API Configuration ───────────────────────────────────
# Comma-separated list of allowed origins for /api/* endpoints
# The /collect endpoint accepts all origins by default
API_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:8080,http://localhost:80
FRONTEND_URL=http://localhost:5173

# ─── ClickHouse Database ─────────────────────────────────
# Time-series analytics database (events, aggregations)
# Docker: http://clickhouse:8123  |  Local: http://localhost:8123
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# ─── Redis Cache & Message Queue ─────────────────────────
# Used for: event queue (BullMQ), query caching, pub/sub (live events)
# Docker: redis://redis:6379  |  Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── PostgreSQL Database ─────────────────────────────────
# Metadata storage: sites, funnels, users
# Docker: postgres  |  Local: localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=insightdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── MaxMind GeoIP Database (OPTIONAL) ───────────────────
# Required for: Live Pulse Map geo-location feature
# Download free database: https://www.maxmind.com/en/geolite2/geolite2-free-geolocation-data
# Leave empty if you don't need geo-location
GEOIP_MMDB_PATH=

# ─── Tracker Configuration ───────────────────────────────
# URL where the tracker script sends analytics events
# This is embedded in your website's tracker configuration
TRACKER_ENDPOINT=http://localhost:3000/collect

# ─── Demo Site Configuration ─────────────────────────────
# Port for the demo website (packages/demo-site)
DEMO_PORT=8080

# ─── Production-Only Settings ────────────────────────────
# Uncomment and configure for production deployments:
#
# REDIS_PASSWORD=your-redis-password
# CLICKHOUSE_PASSWORD=your-clickhouse-password
# POSTGRES_PASSWORD=strong-production-password
#
# For Docker Compose production override:
# docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d
