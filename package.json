{
    "name": "insight-os",
    "private": true,
    "version": "0.1.0",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "npm run -ws build",
        "test": "npm run tracker:build && vitest run",
        "test:watch": "vitest",
        "tracker:build": "npm --workspace packages/tracker run build",
        "api:test": "npm --workspace packages/api run test"
    },
    "devDependencies": {
        "supertest": "^7.1.3",
        "vitest": "^2.1.9",
        "ws": "^8.18.0"
    }
}